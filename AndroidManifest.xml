name: Build APK

# Tu dong build APK moi khi push code, hoac bam chay tay (workflow_dispatch).
on:
  push:
    branches: [main, master]
  workflow_dispatch:

jobs:
  build:
    runs-on: ubuntu-latest
    steps:
      - name: Checkout code
        uses: actions/checkout@v4

      - name: Setup Java
        uses: actions/setup-java@v4
        with:
          distribution: temurin
          java-version: "17"

      - name: Setup Flutter
        uses: subosito/flutter-action@v2
        with:
          channel: stable

      - name: Sinh scaffold Android (gradle, wrapper...)
        run: flutter create --org com.example --project-name printer_ip_tool .

      - name: Tai thu vien
        run: flutter pub get

      - name: Build APK (release)
        run: flutter build apk --release

      - name: Tai APK len Artifacts
        uses: actions/upload-artifact@v4
        with:
          name: app-release-apk
          path: build/app/outputs/flutter-apk/app-release.apk
          if-no-files-found: error
